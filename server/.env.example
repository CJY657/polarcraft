# PolarCraft Backend API Environment Variables

# 服务器配置 / Server Configuration
NODE_ENV=development
PORT=3001
API_URL=http://localhost:3001

# 数据库配置 / Database Configuration
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB_NAME=polarcraft
DB_MAX_POOL_SIZE=10

# JWT 配置 / JWT Configuration
# 请在生产环境中使用强随机字符串 / Use strong random strings in production
JWT_ACCESS_SECRET=your_access_secret_change_this_in_production
JWT_REFRESH_SECRET=your_refresh_secret_change_this_in_production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# 密码策略 / Password Policy
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBER=true
PASSWORD_REQUIRE_SPECIAL_CHAR=true
BCRYPT_ROUNDS=12

# 速率限制 / Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS 配置 / CORS Configuration
CORS_ORIGIN=http://localhost:5173

# 验证码配置 / CAPTCHA Configuration
CAPTCHA_LENGTH=4
CAPTCHA_WIDTH=120
CAPTCHA_HEIGHT=40

# 安全配置 / Security Configuration
# 请在生产环境中使用强随机字符串 / Use strong random strings in production
CSRF_SECRET=your_csrf_secret_change_this
COOKIE_SECRET=your_cookie_secret_change_this

# 前端 URL（用于密码重置链接）/ Frontend URL (for password reset links)
FRONTEND_URL=http://localhost:5173

# 邮件配置 / Email Configuration
EMAIL_ENABLED=false
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_specific_password
EMAIL_FROM=noreply@polarcraft.com
EMAIL_FROM_NAME=PolarCraft

# 邮件服务说明 / Email Service Notes:
# - Gmail: Enable 2FA and create an App Password at https://myaccount.google.com/apppasswords
# - Outlook/Hotmail: Use smtp-mail.outlook.com:587
# - SendGrid: Use smtp.sendgrid.net:587 with your API key as password
# - 邮箱说明:
#   - Gmail: 开启两步验证并创建应用专用密码 https://myaccount.google.com/apppasswords
#   - Outlook/Hotmail: 使用 smtp-mail.outlook.com:587
#   - SendGrid: 使用 smtp.sendgrid.net:587，API key 作为密码

# 日志配置 / Logging Configuration
LOG_LEVEL=info
LOG_ENABLED=true
